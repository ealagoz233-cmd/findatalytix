# Bu dosyayı ".env" adıyla kopyala ve anahtarlarını gir.
# ANAHTARLARI ASLA repoya/paylaşıma koyma!
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GROQ (ONERILEN - ucretsiz, cok comert kota, hizli Llama 3.3 70B): https://console.groq.com/keys
# Doldurursan TUM AI cagrilari Groq'a gider (Gemini'nin dar/sifir ucretsiz limitine takilmazsin).
GROQ_API_KEY=
# Roller (varsayılan: claude analist, gemini hakem). Ters çevirmek için: AI_ANALYST=gemini
AI_ANALYST=claude
